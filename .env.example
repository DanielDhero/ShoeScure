# ============================================================
# ShoeScure — contoh environment variables
# Salin ke `.env` (lokal) atau set di dashboard hosting (Vercel).
# JANGAN commit `.env` asli — sudah di-ignore lewat .gitignore.
# ============================================================

# --- Database (Neon PostgreSQL) ---
# DATABASE_URL : koneksi runtime. Di produksi/serverless WAJIB pakai
#                connection string POOLED (host mengandung `-pooler`).
# DIRECT_URL   : koneksi langsung (tanpa pooler), khusus `prisma migrate`.
# Ambil keduanya dari Neon Console → Connection Details (toggle "Pooled connection").
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# --- Auth ---
# Rahasia penandatanganan JWT. WAJIB unik & acak di produksi.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="ganti-dengan-string-acak-panjang"

# --- Midtrans (pembayaran) ---
# Sandbox: ambil dari https://dashboard.sandbox.midtrans.com → Settings → Access Keys
# Produksi: ambil dari https://dashboard.midtrans.com (butuh verifikasi bisnis) & set IS_PRODUCTION=true
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"

# --- Cloudinary (upload foto) ---
# Dashboard: https://cloudinary.com → Account Details
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Untuk Upload Widget di browser — cloud name sama; preset = unsigned preset.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="shoescure_unsigned"
